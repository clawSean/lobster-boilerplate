#!/usr/bin/env bash
set -euo pipefail

OUT_FILE="${1:-/run/openclaw/env}"
OUT_DIR="$(dirname "$OUT_FILE")"
mkdir -p "$OUT_DIR"
umask 077

# Requires: op CLI + authenticated session (service account or op signin)
# Replace references below with your own vault/item/field paths.
cat >"$OUT_FILE" <<EOT
OPENCLAW_GATEWAY_TOKEN=$(op read "op://OpenClaw/Runtime/OPENCLAW_GATEWAY_TOKEN")
TELEGRAM_BOT_TOKEN=$(op read "op://OpenClaw/Runtime/TELEGRAM_BOT_TOKEN")
OPENAI_API_KEY=$(op read "op://OpenClaw/Runtime/OPENAI_API_KEY")
BRAVE_API_KEY=$(op read "op://OpenClaw/Runtime/BRAVE_API_KEY")
EOT

chmod 600 "$OUT_FILE"
